{
  "version": 2,
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "backend/main.py"
    }
  ],
  "env": {
    "MONGODB_URI": "@mongodb_uri",
    "JWT_SECRET": "@jwt_secret",
    "OPENWEATHER_API_KEY": "@openweather_api_key",
    "GEMINI_API_KEY": "@gemini_api_key",
    "FRONTEND_URL": "https://rythumitra.netlify.app"
  }
}
